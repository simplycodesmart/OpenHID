<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenHardwarePlatform.Desktop.ViewModels"
             xmlns:conv="using:OpenHardwarePlatform.Desktop.Converters"
             x:Class="OpenHardwarePlatform.Desktop.Views.ConnectionManagerView"
             x:DataType="vm:ConnectionManagerViewModel">
  <Grid RowDefinitions="Auto,Auto,*" Margin="16">
    <Border Classes="card" Margin="0,0,0,12">
      <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto">
        <StackPanel Spacing="4">
          <TextBlock Text="CONNECTION STATUS" FontSize="10" LetterSpacing="1.2" Opacity="0.5" FontFamily="JetBrains Mono, Consolas, monospace" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Ellipse Width="10" Height="10" VerticalAlignment="Center">
              <Ellipse.Fill>
                <SolidColorBrush Color="{Binding IsConnected, Converter={x:Static conv:ObjectConverters.ToBrush}, ConverterParameter=#6BFF8F|#FFB4AB}" />
              </Ellipse.Fill>
            </Ellipse>
            <TextBlock Text="{Binding ConnectionStatus}" FontSize="16" FontWeight="SemiBold" />
          </StackPanel>
          <TextBlock Text="{Binding SelectedDevice.DisplayName, FallbackValue='No device selected'}"
                     FontSize="12" Opacity="0.6" Margin="0,4,0,0" />
        </StackPanel>
        <Button Grid.Column="1" Classes="primary" Content="⚡ Connect" Command="{Binding ConnectCommand}"
                Margin="0,0,8,0" VerticalAlignment="Center" IsEnabled="{Binding !IsConnected}" />
        <Button Grid.Column="2" Classes="ghost" Content="⏏ Disconnect" Command="{Binding DisconnectCommand}"
                VerticalAlignment="Center" IsEnabled="{Binding IsConnected}" />
      </Grid>
    </Border>

    <TextBlock Grid.Row="1" Text="ACTIVE SESSIONS" FontSize="10" LetterSpacing="1.2" FontWeight="Bold"
               Opacity="0.5" Margin="0,0,0,8" FontFamily="JetBrains Mono, Consolas, monospace" />

    <Border Grid.Row="2" Classes="card" Padding="0">
      <ListBox ItemsSource="{Binding ActiveConnections}" Background="Transparent">
        <ListBox.ItemTemplate>
          <DataTemplate x:DataType="vm:ConnectionEntry">
            <Border Padding="14,10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
              <Grid ColumnDefinitions="Auto,*,Auto">
                <Ellipse Width="8" Height="8" Fill="{DynamicResource TertiaryBrush}" Margin="0,0,12,0" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Spacing="2">
                  <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding DevicePath}" FontSize="10" Opacity="0.45" FontFamily="JetBrains Mono, Consolas, monospace" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <Border Grid.Column="2" Background="#1A6BFF8F" CornerRadius="4" Padding="8,3" VerticalAlignment="Center">
                  <TextBlock Text="LIVE" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TertiaryBrush}" />
                </Border>
              </Grid>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </Border>
  </Grid>
</UserControl>
