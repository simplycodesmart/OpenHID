<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenHardwarePlatform.Desktop.ViewModels"
             xmlns:models="using:OpenHardwarePlatform.Desktop.Models"
             x:Class="OpenHardwarePlatform.Desktop.Views.DeviceExplorerView"
             x:DataType="vm:DeviceExplorerViewModel">
  <Grid RowDefinitions="Auto,*" Margin="16">
    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
      <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
        <Border Background="#1A00E5FF" CornerRadius="6" Padding="8,4">
          <TextBlock Text="{Binding DeviceCount, StringFormat={}{0} FOUND}" FontSize="11" FontWeight="Bold"
                     Foreground="{DynamicResource PrimaryBrush}" FontFamily="JetBrains Mono, Consolas, monospace" />
        </Border>
        <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="{DynamicResource OnSurfaceVariantBrush}" VerticalAlignment="Center" />
      </StackPanel>
      <Button Grid.Column="1" Classes="ghost" Content="↻ Rescan" Command="{Binding RefreshDevicesCommand}" />
    </Grid>

    <ScrollViewer Grid.Row="1">
      <ItemsControl ItemsSource="{Binding FilteredDevices}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="models:DeviceInfoModel">
            <Border Classes="device-card" Width="280" Margin="0,0,12,12"
                    PointerPressed="OnDeviceCardPressed" Tag="{Binding}">
              <StackPanel Spacing="10">
                <Grid ColumnDefinitions="Auto,*,Auto">
                  <Border Width="40" Height="40" CornerRadius="10" Background="#1A00E5FF">
                    <TextBlock Text="🖥" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Manufacturer}" FontSize="11" Opacity="0.6" TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                  <Border Grid.Column="2" Background="#1A6BFF8F" CornerRadius="4" Padding="6,2" VerticalAlignment="Top">
                    <TextBlock Text="HID" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TertiaryBrush}" />
                  </Border>
                </Grid>
                <Border Height="1" Background="{DynamicResource BorderBrush}" />
                <Grid ColumnDefinitions="*,*">
                  <StackPanel Spacing="2">
                    <TextBlock Text="VENDOR" FontSize="9" LetterSpacing="1" Opacity="0.45" FontFamily="JetBrains Mono, Consolas, monospace" />
                    <TextBlock Text="{Binding VendorIdHex}" FontSize="12" FontFamily="JetBrains Mono, Consolas, monospace" Foreground="{DynamicResource PrimarySoftBrush}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock Text="PRODUCT" FontSize="9" LetterSpacing="1" Opacity="0.45" FontFamily="JetBrains Mono, Consolas, monospace" />
                    <TextBlock Text="{Binding ProductIdHex}" FontSize="12" FontFamily="JetBrains Mono, Consolas, monospace" Foreground="{DynamicResource SecondaryBrush}" />
                  </StackPanel>
                </Grid>
                <TextBlock Text="{Binding DevicePath}" FontSize="10" Opacity="0.4" TextTrimming="CharacterEllipsis"
                           FontFamily="JetBrains Mono, Consolas, monospace" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</UserControl>
