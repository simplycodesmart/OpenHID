<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenHardwarePlatform.Desktop.ViewModels"
             x:Class="OpenHardwarePlatform.Desktop.Views.LiveMonitorView"
             x:DataType="vm:LiveMonitorViewModel">
  <Grid RowDefinitions="Auto,*" Margin="16">
    <Grid ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,12">
      <TextBox Text="{Binding FilterText}" Watermark="Filter packets..." Margin="0,0,10,0" />
      <Button Grid.Column="1" Classes="primary" Command="{Binding ToggleMonitoringCommand}" Margin="0,0,8,0">
        <TextBlock>
          <TextBlock.Text>
            <MultiBinding StringFormat="{}{0}">
              <Binding Path="IsMonitoring" />
            </MultiBinding>
          </TextBlock.Text>
        </TextBlock>
        <Button.Content>
          <Panel>
            <TextBlock Text="▶ Start" IsVisible="{Binding !IsMonitoring}" />
            <TextBlock Text="⏸ Pause" IsVisible="{Binding IsMonitoring}" />
          </Panel>
        </Button.Content>
      </Button>
      <Button Grid.Column="2" Classes="ghost" Content="Clear" Command="{Binding ClearPacketsCommand}" Margin="0,0,8,0" />
      <Border Grid.Column="3" Background="{DynamicResource SurfaceHighBrush}" CornerRadius="6" Padding="10,6" VerticalAlignment="Center">
        <TextBlock Text="{Binding StatusText}" FontSize="11" FontFamily="JetBrains Mono, Consolas, monospace" Opacity="0.7" />
      </Border>
    </Grid>

    <Border Grid.Row="1" Classes="card" Padding="0">
      <Grid RowDefinitions="Auto,*">
        <Border Background="{DynamicResource SurfaceHighBrush}" Padding="12,8">
          <Grid ColumnDefinitions="100,70,60,60,*">
            <TextBlock Text="TIME" FontSize="10" FontWeight="Bold" Opacity="0.5" FontFamily="JetBrains Mono, Consolas, monospace" />
            <TextBlock Grid.Column="1" Text="DIR" FontSize="10" FontWeight="Bold" Opacity="0.5" FontFamily="JetBrains Mono, Consolas, monospace" />
            <TextBlock Grid.Column="2" Text="ID" FontSize="10" FontWeight="Bold" Opacity="0.5" FontFamily="JetBrains Mono, Consolas, monospace" />
            <TextBlock Grid.Column="3" Text="LEN" FontSize="10" FontWeight="Bold" Opacity="0.5" FontFamily="JetBrains Mono, Consolas, monospace" />
            <TextBlock Grid.Column="4" Text="HEX" FontSize="10" FontWeight="Bold" Opacity="0.5" FontFamily="JetBrains Mono, Consolas, monospace" />
          </Grid>
        </Border>
        <ListBox Grid.Row="1" ItemsSource="{Binding FilteredPackets}" Background="Transparent">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:PacketEntry">
              <Border Padding="12,7" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="100,70,60,60,*">
                  <TextBlock Text="{Binding TimestampStr}" FontSize="11" FontFamily="JetBrains Mono, Consolas, monospace" Opacity="0.55" />
                  <TextBlock Grid.Column="1" Text="{Binding Direction}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" />
                  <TextBlock Grid.Column="2" Text="{Binding ReportId}" FontSize="11" FontFamily="JetBrains Mono, Consolas, monospace" />
                  <TextBlock Grid.Column="3" Text="{Binding Length}" FontSize="11" Opacity="0.6" />
                  <TextBlock Grid.Column="4" Text="{Binding Hex}" FontSize="11" FontFamily="JetBrains Mono, Consolas, monospace" Foreground="{DynamicResource PrimarySoftBrush}" TextTrimming="CharacterEllipsis" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>
  </Grid>
</UserControl>
