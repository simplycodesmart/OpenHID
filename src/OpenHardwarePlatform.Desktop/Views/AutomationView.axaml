<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenHardwarePlatform.Desktop.ViewModels"
             x:Class="OpenHardwarePlatform.Desktop.Views.AutomationView"
             x:DataType="vm:AutomationViewModel">
  <Grid ColumnDefinitions="*,*" Margin="16">
    <StackPanel Spacing="12" Margin="0,0,10,0">
      <Border Classes="card">
        <StackPanel Spacing="10">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="SCRIPT EDITOR" FontSize="10" LetterSpacing="1.2" FontWeight="Bold" Opacity="0.5" FontFamily="JetBrains Mono, Consolas, monospace" VerticalAlignment="Center" />
            <Button Grid.Column="1" Classes="ghost" Content="Load Example" Command="{Binding LoadExampleCommand}" Padding="10,4" />
          </Grid>
          <TextBox Text="{Binding ScriptText}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="220"
                   FontFamily="JetBrains Mono, Consolas, monospace" FontSize="12"
                   Watermark="// Commands: OUT hex, WAIT ms, FEATURE hex" />
          <Grid ColumnDefinitions="*,*,Auto,Auto">
            <StackPanel Margin="0,0,8,0">
              <TextBlock Text="Repeat" FontSize="11" Opacity="0.55" Margin="0,0,0,4" />
              <TextBox Text="{Binding RepeatCount}" FontFamily="JetBrains Mono, Consolas, monospace" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="0,0,8,0">
              <TextBlock Text="Delay ms" FontSize="11" Opacity="0.55" Margin="0,0,0,4" />
              <TextBox Text="{Binding DelayMs}" FontFamily="JetBrains Mono, Consolas, monospace" />
            </StackPanel>
            <Button Grid.Column="2" Classes="primary" Content="▶ Run" Command="{Binding RunScriptCommand}"
                    VerticalAlignment="Bottom" Margin="0,0,8,0" IsEnabled="{Binding !IsRunning}" />
            <Button Grid.Column="3" Classes="ghost" Content="■ Stop" Command="{Binding StopScriptCommand}"
                    VerticalAlignment="Bottom" IsEnabled="{Binding IsRunning}" />
          </Grid>
          <TextBlock Text="{Binding StatusText}" FontSize="11" Opacity="0.6" FontFamily="JetBrains Mono, Consolas, monospace" />
        </StackPanel>
      </Border>
    </StackPanel>

    <Border Grid.Column="1" Classes="card" Padding="0">
      <Grid RowDefinitions="Auto,*">
        <Border Padding="14,10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="EXECUTION HISTORY" FontSize="11" FontWeight="Bold" Opacity="0.6" VerticalAlignment="Center" />
            <Button Grid.Column="1" Classes="ghost" Content="Clear" Command="{Binding ClearHistoryCommand}" Padding="10,4" />
          </Grid>
        </Border>
        <ListBox Grid.Row="1" ItemsSource="{Binding ScriptHistory}" Background="Transparent">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:ScriptEntry">
              <Border Padding="12,8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="90,*,Auto">
                  <TextBlock Text="{Binding Timestamp, StringFormat=HH:mm:ss.fff}" FontSize="11" FontFamily="JetBrains Mono, Consolas, monospace" Opacity="0.5" />
                  <TextBlock Grid.Column="1" Text="{Binding Command}" FontFamily="JetBrains Mono, Consolas, monospace" FontSize="12" TextTrimming="CharacterEllipsis" />
                  <Border Grid.Column="2" Background="#1A6BFF8F" CornerRadius="4" Padding="6,2">
                    <TextBlock Text="{Binding Status}" FontSize="10" Foreground="{DynamicResource TertiaryBrush}" />
                  </Border>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>
  </Grid>
</UserControl>
