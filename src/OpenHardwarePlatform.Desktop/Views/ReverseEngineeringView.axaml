<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenHardwarePlatform.Desktop.ViewModels"
             xmlns:conv="using:OpenHardwarePlatform.Desktop.Converters"
             x:Class="OpenHardwarePlatform.Desktop.Views.ReverseEngineeringView"
             x:DataType="vm:ReverseEngineeringViewModel">
  <Grid ColumnDefinitions="*,1.3*" Margin="16">
    <StackPanel Spacing="12" Margin="0,0,10,0">
      <Border Classes="card">
        <StackPanel Spacing="10">
          <TextBlock Text="PACKET INPUT" FontSize="10" LetterSpacing="1.2" FontWeight="Bold" Opacity="0.5" FontFamily="JetBrains Mono, Consolas, monospace" />
          <TextBox Text="{Binding InputData}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="120"
                   Watermark="Paste unknown report hex..."
                   FontFamily="JetBrains Mono, Consolas, monospace" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Classes="primary" Content="🔬 Analyze" Command="{Binding AnalyzeCommand}" />
            <Button Classes="ghost" Content="Clear" Command="{Binding ClearCommand}" />
          </StackPanel>
        </StackPanel>
      </Border>
      <Border Classes="card">
        <StackPanel Spacing="8">
          <TextBlock Text="ANALYSIS" FontSize="10" LetterSpacing="1.2" FontWeight="Bold" Opacity="0.5" FontFamily="JetBrains Mono, Consolas, monospace" />
          <TextBlock Text="{Binding AnalysisResult}" FontFamily="JetBrains Mono, Consolas, monospace" FontSize="12"
                     TextWrapping="Wrap" Foreground="{DynamicResource PrimarySoftBrush}" />
          <Border Background="#1A6F00BE" CornerRadius="6" Padding="10,6" IsVisible="{Binding SuggestedProtocol, Converter={x:Static conv:StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding SuggestedProtocol, StringFormat=Protocol guess: {0}}" FontSize="12" Foreground="{DynamicResource SecondaryBrush}" />
          </Border>
        </StackPanel>
      </Border>
    </StackPanel>

    <Border Grid.Column="1" Classes="card" Padding="0">
      <Grid RowDefinitions="Auto,*">
        <Border Background="{DynamicResource SurfaceHighBrush}" Padding="12,8">
          <Grid ColumnDefinitions="60,70,100,*,*">
            <TextBlock Text="OFF" FontSize="10" FontWeight="Bold" Opacity="0.5" FontFamily="JetBrains Mono, Consolas, monospace" />
            <TextBlock Grid.Column="1" Text="HEX" FontSize="10" FontWeight="Bold" Opacity="0.5" FontFamily="JetBrains Mono, Consolas, monospace" />
            <TextBlock Grid.Column="2" Text="BINARY" FontSize="10" FontWeight="Bold" Opacity="0.5" FontFamily="JetBrains Mono, Consolas, monospace" />
            <TextBlock Grid.Column="3" Text="BITS" FontSize="10" FontWeight="Bold" Opacity="0.5" FontFamily="JetBrains Mono, Consolas, monospace" />
            <TextBlock Grid.Column="4" Text="GUESS" FontSize="10" FontWeight="Bold" Opacity="0.5" FontFamily="JetBrains Mono, Consolas, monospace" />
          </Grid>
        </Border>
        <ListBox Grid.Row="1" ItemsSource="{Binding DetectedPatterns}" Background="Transparent">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:PatternMatch">
              <Border Padding="12,7" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="60,70,100,*,*">
                  <TextBlock Text="{Binding ByteOffset}" FontSize="11" Opacity="0.55" />
                  <TextBlock Grid.Column="1" Text="{Binding HexValue}" FontSize="11" FontFamily="JetBrains Mono, Consolas, monospace" Foreground="{DynamicResource PrimaryBrush}" />
                  <TextBlock Grid.Column="2" Text="{Binding BinaryValue}" FontSize="11" FontFamily="JetBrains Mono, Consolas, monospace" Opacity="0.7" />
                  <TextBlock Grid.Column="3" Text="{Binding BitPattern}" FontSize="11" TextTrimming="CharacterEllipsis" />
                  <TextBlock Grid.Column="4" Text="{Binding Significance}" FontSize="11" Foreground="{DynamicResource SecondaryBrush}" TextTrimming="CharacterEllipsis" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>
  </Grid>
</UserControl>
