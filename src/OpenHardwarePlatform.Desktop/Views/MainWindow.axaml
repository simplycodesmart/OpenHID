<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenHardwarePlatform.Desktop.ViewModels"
        xmlns:views="using:OpenHardwarePlatform.Desktop.Views"
        xmlns:conv="using:OpenHardwarePlatform.Desktop.Converters"
        x:Class="OpenHardwarePlatform.Desktop.Views.MainWindow"
        Title="OpenHID — HID Engineering Toolkit"
        Width="1440" Height="920"
        MinWidth="1100" MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgBrush}">

  <Window.DataTemplates>
    <DataTemplate DataType="vm:DeviceExplorerViewModel">
      <views:DeviceExplorerView />
    </DataTemplate>
    <DataTemplate DataType="vm:DeviceInspectorViewModel">
      <views:DeviceInspectorView />
    </DataTemplate>
    <DataTemplate DataType="vm:ConnectionManagerViewModel">
      <views:ConnectionManagerView />
    </DataTemplate>
    <DataTemplate DataType="vm:DescriptorExplorerViewModel">
      <views:DescriptorExplorerView />
    </DataTemplate>
    <DataTemplate DataType="vm:HidConsoleViewModel">
      <views:HidConsoleView />
    </DataTemplate>
    <DataTemplate DataType="vm:LiveMonitorViewModel">
      <views:LiveMonitorView />
    </DataTemplate>
    <DataTemplate DataType="vm:PacketDecoderViewModel">
      <views:PacketDecoderView />
    </DataTemplate>
    <DataTemplate DataType="vm:PacketLoggerViewModel">
      <views:PacketLoggerView />
    </DataTemplate>
    <DataTemplate DataType="vm:AutomationViewModel">
      <views:AutomationView />
    </DataTemplate>
    <DataTemplate DataType="vm:ReverseEngineeringViewModel">
      <views:ReverseEngineeringView />
    </DataTemplate>
    <DataTemplate DataType="vm:DocumentationGeneratorViewModel">
      <views:DocumentationView />
    </DataTemplate>
  </Window.DataTemplates>

  <Grid RowDefinitions="56,*,28">
    <!-- TOP BAR -->
    <Border Grid.Row="0" Background="#CC10131A" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,0">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
          <Border Width="32" Height="32" CornerRadius="8" Background="#1A00E5FF">
            <TextBlock Text="⚡" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <StackPanel Spacing="0" VerticalAlignment="Center">
            <TextBlock Text="OpenHID" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource PrimarySoftBrush}" />
            <TextBlock Text="HID ENGINEERING TOOLKIT" FontSize="9" LetterSpacing="1.5" Foreground="{DynamicResource OutlineBrush}" FontFamily="JetBrains Mono, Consolas, monospace" />
          </StackPanel>
        </StackPanel>

        <Border Grid.Column="1" MaxWidth="420" HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{DynamicResource SurfaceLowBrush}" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="8" Padding="10,0" Height="36">
          <Grid ColumnDefinitions="Auto,*">
            <TextBlock Text="⌕" FontSize="14" Foreground="{DynamicResource OutlineBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox Grid.Column="1" Text="{Binding SearchText}" Watermark="Search devices, VID, PID..."
                     BorderThickness="0" Background="Transparent" VerticalAlignment="Center" Padding="0" />
          </Grid>
        </Border>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <Border Background="{DynamicResource SurfaceHighBrush}" CornerRadius="20" Padding="10,4">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Ellipse Width="7" Height="7" Fill="{DynamicResource TertiaryBrush}" />
              <TextBlock Text="{Binding DeviceCount, StringFormat={}{0} devices}" FontSize="12"
                         Foreground="{DynamicResource OnSurfaceVariantBrush}" VerticalAlignment="Center" />
            </StackPanel>
          </Border>
          <Button Classes="primary" Content="↻ Refresh" Command="{Binding RefreshDevicesCommand}" Height="34" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- BODY -->
    <Grid Grid.Row="1" ColumnDefinitions="240,*">
      <!-- SIDEBAR -->
      <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
        <Grid RowDefinitions="*,Auto">
          <ScrollViewer Grid.Row="0" Padding="10,12">
            <ItemsControl ItemsSource="{Binding NavItems}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:NavItem">
                  <Button Classes="nav" Click="OnNavClick" Tag="{Binding Index}" Margin="0,2"
                          Classes.active="{Binding IsActive}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                      <TextBlock Text="{Binding Icon}" FontSize="15" Width="22" TextAlignment="Center" />
                      <StackPanel Spacing="1">
                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Description}" FontSize="10" Opacity="0.55" />
                      </StackPanel>
                    </StackPanel>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

          <Border Grid.Row="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12">
            <StackPanel Spacing="8">
              <TextBlock Text="SELECTED DEVICE" FontSize="10" LetterSpacing="1.2" FontWeight="Bold"
                         Foreground="{DynamicResource OutlineBrush}" FontFamily="JetBrains Mono, Consolas, monospace" />
              <Border Classes="card" Padding="10" IsVisible="{Binding SelectedDevice, Converter={x:Static conv:ObjectConverters.IsNotNull}}">
                <StackPanel Spacing="4">
                  <TextBlock Text="{Binding SelectedDevice.DisplayName}" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis" />
                  <TextBlock Text="{Binding SelectedDevice.Summary}" FontSize="11" FontFamily="JetBrains Mono, Consolas, monospace"
                             Foreground="{DynamicResource PrimaryBrush}" />
                </StackPanel>
              </Border>
              <TextBlock Text="No device selected" FontSize="11" Opacity="0.5"
                         IsVisible="{Binding SelectedDevice, Converter={x:Static conv:ObjectConverters.IsNull}}" />
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <!-- MAIN CONTENT -->
      <Grid Grid.Column="1" RowDefinitions="Auto,*" Background="{DynamicResource BgBrush}">
        <Border Grid.Row="0" Padding="24,18,24,8">
          <StackPanel Spacing="4">
            <TextBlock Text="{Binding PageTitle}" FontSize="24" FontWeight="Bold" />
            <TextBlock Text="{Binding PageSubtitle}" FontSize="13" Foreground="{DynamicResource OnSurfaceVariantBrush}" />
          </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="16,0,16,12" Classes="card" Padding="0" ClipToBounds="True">
          <ContentControl Content="{Binding CurrentPage}" Margin="0" />
        </Border>
      </Grid>
    </Grid>

    <!-- STATUS BAR -->
    <Border Grid.Row="2" Background="{DynamicResource SurfaceLowBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="14,0">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Ellipse Width="6" Height="6" Fill="{DynamicResource PrimaryBrush}" />
          <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="{DynamicResource OnSurfaceVariantBrush}"
                     FontFamily="JetBrains Mono, Consolas, monospace" VerticalAlignment="Center" />
        </StackPanel>
        <TextBlock Grid.Column="1" Text="v1.0.0  ·  OpenHID" FontSize="11" Opacity="0.45" VerticalAlignment="Center" />
      </Grid>
    </Border>
  </Grid>
</Window>
