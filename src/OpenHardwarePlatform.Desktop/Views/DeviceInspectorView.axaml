<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenHardwarePlatform.Desktop.ViewModels"
             xmlns:conv="using:OpenHardwarePlatform.Desktop.Converters"
             x:Class="OpenHardwarePlatform.Desktop.Views.DeviceInspectorView"
             x:DataType="vm:DeviceInspectorViewModel">
  <ScrollViewer Margin="16">
    <StackPanel Spacing="16">
      <Border Classes="card" IsVisible="{Binding SelectedDevice, Converter={x:Static conv:ObjectConverters.IsNull}}">
        <StackPanel HorizontalAlignment="Center" Spacing="8" Margin="40">
          <TextBlock Text="📋" FontSize="40" HorizontalAlignment="Center" Opacity="0.4" />
          <TextBlock Text="Select a device from Device Explorer" Opacity="0.6" HorizontalAlignment="Center" />
        </StackPanel>
      </Border>

      <StackPanel Spacing="16" IsVisible="{Binding SelectedDevice, Converter={x:Static conv:ObjectConverters.IsNotNull}}">
        <Border Classes="card">
          <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
            <Border Width="56" Height="56" CornerRadius="14" Background="#1A00E5FF" Margin="0,0,16,0">
              <TextBlock Text="🔌" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
              <TextBlock Text="{Binding Product}" FontSize="20" FontWeight="Bold" />
              <TextBlock Text="{Binding Manufacturer}" FontSize="13" Foreground="{DynamicResource OnSurfaceVariantBrush}" />
            </StackPanel>
            <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="4">
              <Button Command="{Binding ConnectCommand}"
                      IsVisible="{Binding IsConnected, Converter={x:Static conv:ObjectConverters.InvertBool}}"
                      Classes="accent"
                      Padding="16,8">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="🔗" />
                  <TextBlock Text="Connect" />
                </StackPanel>
              </Button>
              <Button Command="{Binding DisconnectCommand}"
                      IsVisible="{Binding IsConnected}"
                      Classes="warning"
                      Padding="16,8">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="⛔" />
                  <TextBlock Text="Disconnect" />
                </StackPanel>
              </Button>
              <TextBlock Text="{Binding ConnectionStatus}" FontSize="11"
                         Foreground="{DynamicResource OutlineBrush}"
                         HorizontalAlignment="Center"
                         IsVisible="{Binding ConnectionStatus, Converter={x:Static conv:StringConverters.IsNotEmpty}}" />
            </StackPanel>
            <Border Grid.Row="1" Grid.ColumnSpan="3" Margin="0,14,0,0" Background="{DynamicResource SurfaceHighBrush}"
                    CornerRadius="8" Padding="12,8">
              <TextBlock Text="{Binding DevicePath}" FontSize="11" FontFamily="JetBrains Mono, Consolas, monospace"
                         Foreground="{DynamicResource OutlineBrush}" TextWrapping="Wrap" />
            </Border>
          </Grid>
        </Border>

        <UniformGrid Columns="3" >
          <Border Classes="card" Margin="0,0,10,10">
            <StackPanel Spacing="6">
              <TextBlock Text="VENDOR ID" FontSize="10" LetterSpacing="1.2" Opacity="0.5" FontFamily="JetBrains Mono, Consolas, monospace" />
              <TextBlock Text="{Binding VendorIdHex}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" FontFamily="JetBrains Mono, Consolas, monospace" />
            </StackPanel>
          </Border>
          <Border Classes="card" Margin="0,0,10,10">
            <StackPanel Spacing="6">
              <TextBlock Text="PRODUCT ID" FontSize="10" LetterSpacing="1.2" Opacity="0.5" FontFamily="JetBrains Mono, Consolas, monospace" />
              <TextBlock Text="{Binding ProductIdHex}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource SecondaryBrush}" FontFamily="JetBrains Mono, Consolas, monospace" />
            </StackPanel>
          </Border>
          <Border Classes="card" Margin="0,0,0,10">
            <StackPanel Spacing="6">
              <TextBlock Text="VERSION" FontSize="10" LetterSpacing="1.2" Opacity="0.5" FontFamily="JetBrains Mono, Consolas, monospace" />
              <TextBlock Text="{Binding Version}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TertiaryBrush}" FontFamily="JetBrains Mono, Consolas, monospace" />
            </StackPanel>
          </Border>
        </UniformGrid>

        <Border Classes="card">
          <StackPanel Spacing="12">
            <TextBlock Text="PROPERTIES" FontSize="11" LetterSpacing="1.5" FontWeight="Bold" Opacity="0.5" FontFamily="JetBrains Mono, Consolas, monospace" />
            <Grid ColumnDefinitions="160,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
              <TextBlock Text="Serial Number" Opacity="0.55" Margin="0,6" />
              <TextBlock Grid.Column="1" Text="{Binding SerialNumber}" FontFamily="JetBrains Mono, Consolas, monospace" Margin="0,6" />
              <TextBlock Grid.Row="1" Text="Transport" Opacity="0.55" Margin="0,6" />
              <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TransportName}" FontFamily="JetBrains Mono, Consolas, monospace" Margin="0,6" Foreground="{DynamicResource PrimarySoftBrush}" />
              <TextBlock Grid.Row="2" Text="Manufacturer" Opacity="0.55" Margin="0,6" />
              <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Manufacturer}" Margin="0,6" />
              <TextBlock Grid.Row="3" Text="Product" Opacity="0.55" Margin="0,6" />
              <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Product}" Margin="0,6" />
              <TextBlock Grid.Row="4" Text="Device Path" Opacity="0.55" Margin="0,6" />
              <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding DevicePath}" FontSize="11" FontFamily="JetBrains Mono, Consolas, monospace" TextWrapping="Wrap" Margin="0,6" Opacity="0.7" />
            </Grid>
          </StackPanel>
        </Border>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
